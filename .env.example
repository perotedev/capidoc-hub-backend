# ── App ──────────────────────────────────────────────────────────
APP_NAME=CapiDoc API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=capidoc
POSTGRES_USER=capidoc
POSTGRES_PASSWORD=capidoc

# ── MongoDB ──────────────────────────────────────────────────────
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=capidoc
MONGO_USER=capidoc
MONGO_PASSWORD=capidoc

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Auth / JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Object storage (S3 / MinIO for local dev) ──────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=capidoc
S3_SECRET_ACCESS_KEY=capidoc12345
S3_BUCKET_NAME=capidoc-files
S3_USE_PATH_STYLE=true
FILE_URL_EXPIRE_SECONDS=86400

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=CapiDoc <no-reply@capidoc.com>

# ── Frontend / links ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
